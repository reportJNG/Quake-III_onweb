{
  "name": "openarena-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "node --check src/main.js && node --check src/engine.js && node --check src/config.js",
    "prepare:assets": "powershell -ExecutionPolicy Bypass -File scripts/prepare-assets.ps1",
    "build:engine": "powershell -ExecutionPolicy Bypass -File scripts/build-engine.ps1",
    "setup": "npm run prepare:assets && npm run build:engine"
  },
  "devDependencies": {
    "vite": "6.4.3"
  }
}
