 static SDL_Window *SDL_window = NULL;
 
+#if defined(__EMSCRIPTEN__)
+static qboolean webPointerLocked = qfalse;
+static unsigned short webMouseButtons = 0;
+static unsigned int webMouseMotions = 0;
+
+static int IN_WebMouseButton( unsigned short button )
+{
+	switch( button )
+	{
+		case 0: return K_MOUSE1;
+		case 1: return K_MOUSE3;
+		case 2: return K_MOUSE2;
+		case 3: return K_MOUSE4;
+		case 4: return K_MOUSE5;
+		default: return K_AUX1 + ( button - 4 ) % 16;
+	}
+}
+
+EMSCRIPTEN_KEEPALIVE void IN_WebSetPointerLock( int active )
+{
+	int button;
+
+	webPointerLocked = active ? qtrue : qfalse;
+	Com_Printf( "Browser mouse: pointer lock %s (motions: %u)\n",
+		webPointerLocked ? "active" : "released", webMouseMotions );
+
+	if( !webPointerLocked )
+	{
+		for( button = 0; button < 5; button++ )
+		{
+			if( webMouseButtons & ( 1u << button ) )
+				Com_QueueEvent( Sys_Milliseconds(), SE_KEY,
+					IN_WebMouseButton( button ), qfalse, 0, NULL );
+		}
+		webMouseButtons = 0;
+	}
+}
+
+EMSCRIPTEN_KEEPALIVE void IN_WebInjectMouseMove( int movementX, int movementY )
+{
+	/* Pointer Lock is the browser's authoritative capture state. SDL's
+	 * mouseActive flag can lag behind it or remain false when JavaScript
+	 * initiated the lock, which must not discard otherwise valid movement. */
+	if( !webPointerLocked || ( !movementX && !movementY ) )
+		return;
+
+	Com_QueueEvent( Sys_Milliseconds(), SE_MOUSE,
+		movementX, movementY, 0, NULL );
+	webMouseMotions++;
+	if( webMouseMotions == 1 )
+		Com_Printf( "Browser mouse: received first motion event\n" );
+	else if( !( webMouseMotions & 255 ) )
+		Com_DPrintf( "Browser mouse: received %u motion events\n", webMouseMotions );
+}
+
+EMSCRIPTEN_KEEPALIVE void IN_WebInjectMouseButton( int button, int active )
+{
+	qboolean down;
+
+	if( !webPointerLocked || button < 0 || button > 4 )
+		return;
+
+	down = active ? qtrue : qfalse;
+	if( down )
+		webMouseButtons |= 1u << button;
+	else
+		webMouseButtons &= ~( 1u << button );
+	Com_QueueEvent( Sys_Milliseconds(), SE_KEY,
+		IN_WebMouseButton( button ), down, 0, NULL );
+	Com_Printf( "Browser mouse: button %d %s\n", button,
+		down ? "down" : "up" );
+}
+
+EMSCRIPTEN_KEEPALIVE void IN_WebInjectMouseWheel( int direction )
+{
+	int key;
+
+	if( !webPointerLocked || direction == 0 )
+		return;
+
+	key = direction > 0 ? K_MWHEELUP : K_MWHEELDOWN;
+	Com_QueueEvent( Sys_Milliseconds(), SE_KEY, key, qtrue, 0, NULL );
+	Com_QueueEvent( Sys_Milliseconds(), SE_KEY, key, qfalse, 0, NULL );
+}
+
+static void IN_InitWebMouse( void )
+{
+	Com_Printf( "Browser mouse: JavaScript-to-native bridge initialized\n" );
+}
